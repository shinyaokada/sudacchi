{
  "name": "sudacchi",
  "version": "0.1.0",
  "description": "AI-powered virtual pet on Slack",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:cli": "tsx src/cli.ts",
    "build": "tsc",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "test": "vitest run",
